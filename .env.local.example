# Copie pra .env.local e preencha.

# OBRIGATÓRIA — pelo menos uma das duas chaves de IA.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# OBRIGATÓRIO — persistência (Postgres + Storage)
# Crie o projeto em https://supabase.com e rode o SQL do schema.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# OBRIGATÓRIO — segurança (login por senha)
# APP_PASSWORD: a senha de acesso. AUTH_SECRET: gere com `openssl rand -hex 32`.
APP_PASSWORD=
AUTH_SECRET=

# (Opcional) trocar modelos
# ANTHROPIC_MODEL=claude-opus-4-8
# GEMINI_TEXT_MODEL=gemini-2.5-flash
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
